# 设备配置文件
# 格式：[设备名]
# description = 设备描述
# sources = 默认源码配置名列表（可选，逗号分隔）
# 如果未指定或为空，则使用所有可用源码

[x86-64]
description = x86-64 lede,openwrt,immortalwrt
sources = lede,openwrt,immortalwrt

[x86-64-lede]
description = x86-64 LEDE
sources = lede

[x86-64-openwrt]
description = x86-64 OpenWrt
sources = openwrt

[x86-64-immortalwrt]
description = x86-64 ImmortalWrt
sources = immortalwrt
